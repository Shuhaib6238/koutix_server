# ─── Koutix Server — Environment Variables ───────────────

# ─── Core ─────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── MongoDB Atlas ────────────────────────────────────────
# Get from: MongoDB Atlas → Database → Connect → Driver
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/koutix_mvp?retryWrites=true&w=majority

# ─── Redis (AWS ElastiCache) ──────────────────────────────
# TLS connection: rediss://  •  Non-TLS: redis://
# Leave empty for local dev (uses in-memory mock)
REDIS_URL=

# ─── Firebase Admin SDK ──────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=koutix-12345
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@koutix-12345.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBA...\n-----END PRIVATE KEY-----\n"

# ─── AWS S3 + CloudFront ─────────────────────────────────
# Bucket region: me-south-1 (Bahrain — lowest UAE latency)
AWS_REGION=me-south-1
AWS_S3_BUCKET=koutix-media-prod
# Leave empty if running on ECS with IAM role attached
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFRONT_DOMAIN=cdn.koutix.com

# ─── Stripe ──────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Get from: Stripe Dashboard → Developers → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — create products in Stripe Dashboard
# Chain plans (AED pricing):
#   chain_starter: AED 499/mo, up to 3 branches
#   chain_growth:  AED 1299/mo, up to 15 branches
#   chain_enterprise: AED 2999/mo, unlimited branches
STRIPE_PRICE_CHAIN_STARTER=price_xxxxx
STRIPE_PRICE_CHAIN_GROWTH=price_xxxxx
STRIPE_PRICE_CHAIN_ENTERPRISE=price_xxxxx

# Standalone plans:
#   single_starter: AED 149/mo, 1 store
#   single_growth:  AED 349/mo, 1 store + promoted listing
STRIPE_PRICE_SINGLE_STARTER=price_xxxxx
STRIPE_PRICE_SINGLE_GROWTH=price_xxxxx

# Promote addon: AED 199/mo per store
STRIPE_PRICE_PROMOTE=price_xxxxx

# ─── Resend (Email) ──────────────────────────────────────
# Get from: resend.com → API Keys
# Used ONLY for branch manager invite emails
RESEND_API_KEY=re_xxxxx
RESEND_FROM=noreply@koutix.com

# ─── Security ────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of payment gateway secrets
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=https://admin.koutix.com,http://localhost:5173

# ─── Frontend URL ────────────────────────────────────────
# Used for invite email set-password links
FRONTEND_URL=https://admin.koutix.com
